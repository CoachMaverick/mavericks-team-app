# ============================================
# Mavericks 12U Team App - Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or real secrets.
# ============================================

# --- Supabase (from your Supabase project dashboard > Connect > Next.js) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key - SERVER SIDE ONLY (used for limited admin/webhook ops, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Stripe (from https://dashboard.stripe.com/test/apikeys and webhooks) ---
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE

# Stripe webhook secret (create endpoint in Stripe dashboard pointing to https://yourdomain.com/api/stripe-webhook)
# Listen for: checkout.session.completed, payment_intent.succeeded, etc.
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SIGNING_SECRET

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production example: https://mavericks-12u.vercel.app

# IMPORTANT for auth (now supports BOTH magic link + email/password):
# 1. In Supabase Dashboard > Authentication > URL Configuration:
#    - Set Site URL to: http://localhost:3000   (this makes {{ .SiteURL }} resolve correctly)
#    - Add Redirect URLs (exact match or wildcards):
#      http://localhost:3000/auth/confirm
#      http://localhost:3000/**
#      (add production equivalents too)
#
# 2. Providers > Email: Enable "Email" provider. You can keep magic links + enable password sign-in/sign-up.
#
# 3. Customize Email Templates (Authentication > Email Templates > Magic Link and Confirm signup):
#    Use this for the link (default templates may need this to point to our handler):
#      {{ .SiteURL }}/auth/confirm?token_hash={{ .TokenHash }}&type={{ .Type }}
#
# 4. In .env.local: NEXT_PUBLIC_APP_URL must match the Site URL above.
#    This ensures the emailRedirectTo we pass in signInWithOtp matches what Supabase expects.
